<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard | Expense Tracker</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-slate-100 text-slate-900">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <header class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold">Admin Dashboard</h1>
        <p class="text-slate-600 mt-1">Manage bills and student payments.</p>
      </div>
      <div class="flex gap-3">
        <% if (currentUser.role === 'superadmin') { %>
          <span class="px-4 py-2 rounded-2xl bg-purple-200 text-purple-700 font-semibold">Superadmin</span>
          <a href="/admin/manage-admins" class="px-4 py-2 rounded-2xl bg-purple-600 text-white hover:bg-purple-700">Manage Admins</a>
        <% } %>
        <span class="px-4 py-2 rounded-2xl bg-slate-200 text-slate-700">Signed in as <strong><%= currentUser.name %></strong></span>
        <a href="/logout" class="px-4 py-2 rounded-2xl bg-red-600 text-white hover:bg-red-700">Logout</a>
      </div>
    </header>

    <% if (error) { %>
      <div class="mb-4 rounded-2xl bg-red-100 text-red-700 p-4"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="mb-4 rounded-2xl bg-emerald-100 text-emerald-700 p-4"><%= success %></div>
    <% } %>

    <section class="grid gap-6 md:grid-cols-2 mb-10">
      <div class="rounded-3xl bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold mb-4">Create new budget</h2>
        <form action="/admin/set-uniform" method="POST" enctype="multipart/form-data" class="space-y-3">
          <div>
            <label class="block text-slate-700 mb-2">Title</label>
            <input name="title" type="text" required class="w-full rounded-2xl border border-slate-300 px-4 py-3" />
          </div>
          <div>
            <label class="block text-slate-700 mb-2">Amount per Student</label>
            <input name="perStudentAmount" type="number" step="0.01" min="0" required class="w-full rounded-2xl border border-slate-300 px-4 py-3" />
          </div>
          <div>
            <label class="block text-slate-700 mb-2">Budget Cover Page</label>
            <input name="billImage" type="file" accept="image/*" required class="w-full text-slate-700" />
          </div>
          <button type="submit" class="w-full bg-indigo-600 text-white rounded-2xl py-3 font-semibold hover:bg-indigo-700">Create Budget</button>
        </form>
      </div>

      <div class="rounded-3xl bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold mb-4">Record Expense / Spend & Upload Bill</h2>
        <form action="/admin/expenses/create" method="POST" enctype="multipart/form-data" class="space-y-3">
          <div>
            <label class="block text-slate-700 mb-2">Title</label>
            <input name="title" type="text" required class="w-full rounded-2xl border border-slate-300 px-4 py-3" />
          </div>
          <div>
            <label class="block text-slate-700 mb-2">Amount</label>
            <input name="amount" type="number" step="0.01" min="0" required class="w-full rounded-2xl border border-slate-300 px-4 py-3" />
          </div>
          <div>
            <label class="block text-slate-700 mb-2">Description (optional)</label>
            <input name="description" type="text" class="w-full rounded-2xl border border-slate-300 px-4 py-3" />
          </div>
          <div>
            <label class="block text-slate-700 mb-2">Bill Image (required - upload a bill receipt/proof)</label>
            <input name="billImage" type="file" accept="image/*" required class="w-full text-slate-700" />
          </div>
          <button type="submit" class="w-full bg-rose-600 text-white rounded-2xl py-3 font-semibold hover:bg-rose-700">Record Expense</button>
        </form>
        <div class="mt-4">
          <a href="/admin/export-csv" class="inline-block bg-slate-800 text-white px-4 py-2 rounded-2xl">Export CSV</a>
        </div>
      </div>
      <div class="rounded-3xl bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold mb-4">Summary</h2>
        <div class="space-y-3">
          <div class="rounded-2xl border border-slate-200 p-4">
            <p class="text-sm text-slate-500">Total Budget Assigned</p>
            <p class="text-2xl font-bold">₹<%= (typeof totalAssigned !== 'undefined' ? totalAssigned : 0).toFixed(2) %></p>
          </div>
          <div class="rounded-2xl border border-slate-200 p-4">
            <p class="text-sm text-slate-500">Total Collected</p>
            <p class="text-2xl font-bold text-emerald-600">₹<%= (typeof totalCollected !== 'undefined' ? totalCollected : 0).toFixed(2) %></p>
          </div>
          <div class="rounded-2xl border border-slate-200 p-4">
            <p class="text-sm text-slate-500">Total Expenses</p>
            <p class="text-2xl font-bold text-rose-600">₹<%= (typeof totalExpenses !== 'undefined' ? totalExpenses : 0).toFixed(2) %></p>
          </div>
          <div class="rounded-2xl border border-slate-200 p-4">
            <p class="text-sm text-slate-500">Net Balance</p>
            <p class="text-2xl font-bold <%= netBalance >= 0 ? 'text-emerald-600' : 'text-rose-600' %>">₹<%= (typeof netBalance !== 'undefined' ? netBalance : 0).toFixed(2) %></p>
          </div>
          <div class="rounded-2xl border border-slate-200 p-4">
            <p class="text-sm text-slate-500">Total Students</p>
            <p class="text-2xl font-bold"> <%= (typeof totalStudents !== 'undefined' ? totalStudents : 0) %> </p>
          </div>
          <div class="rounded-2xl border border-slate-200 p-4">
            <p class="text-sm text-slate-500">Payments Paid</p>
            <p class="text-2xl font-bold text-emerald-600"> <%= (typeof totalPaidCount !== 'undefined' ? totalPaidCount : 0) %> </p>
          </div>
          <div class="rounded-2xl border border-slate-200 p-4">
            <p class="text-sm text-slate-500">Payments Due</p>
            <p class="text-2xl font-bold text-rose-600"> <%= (typeof totalDueCount !== 'undefined' ? totalDueCount : 0) %> </p>
          </div>
        </div>
        <div class="mt-6 flex gap-2">
          <a href="/admin/students" class="inline-block bg-indigo-600 text-white px-4 py-2 rounded-2xl hover:bg-indigo-700">View Student Summary</a>
          <% if (currentUser.role === 'superadmin') { %>
            <button onclick="confirmReset()" class="inline-block bg-red-700 text-white px-4 py-2 rounded-2xl hover:bg-red-800">Reset Planning</button>
          <% } %>
        </div>
      </div>
      <% if (currentUser.role === 'superadmin') { %>
      <div class="rounded-3xl bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold mb-4">Pending Admin Requests</h2>
        <% if (pendingRequests && pendingRequests.length > 0) { %>
          <div class="space-y-3">
            <% pendingRequests.forEach((u) => { %>
              <div class="rounded-2xl border border-slate-200 p-4 flex items-center justify-between">
                <div>
                  <p class="font-semibold"><%= u.name %> (<%= u.rollNumber %>)</p>
                  <p class="text-sm text-slate-500">Requested admin access</p>
                </div>
                <div class="flex items-center gap-2">
                  <form action="/admin/approve/<%= u._id %>" method="POST">
                    <button type="submit" class="rounded-2xl bg-emerald-600 px-4 py-2 text-white">Approve</button>
                  </form>
                  <form action="/admin/reject/<%= u._id %>" method="POST">
                    <button type="submit" class="rounded-2xl bg-rose-600 px-4 py-2 text-white">Reject</button>
                  </form>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p class="text-slate-500">No pending requests.</p>
        <% } %>
      </div>
      <% } %>

    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold mb-4">Budgets</h2>
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        <% bills.forEach((bill) => { %>
          <div class="rounded-3xl bg-white overflow-hidden shadow-sm">
            <% if (bill.billImage) { %>
              <img src="<%= bill.billImage %>" alt="Bill image" class="h-48 w-full object-cover" />
            <% } else { %>
              <div class="h-48 w-full bg-slate-100 flex items-center justify-center text-slate-500">No image</div>
            <% } %>
            <div class="p-5">
              <h3 class="text-lg font-semibold mb-2"><%= bill.title %></h3>
              <p class="text-slate-600 mb-2">Amount: ₹<%= bill.totalAmount.toFixed(2) %></p>
              <p class="text-sm text-slate-500">Uploaded on <%= bill.date.toDateString() %></p>
            </div>
          </div>
        <% }); %>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-semibold mb-4">Student Payment Status</h2>
      <div class="overflow-x-auto rounded-3xl bg-white shadow-sm border border-slate-200">
        <table class="min-w-full divide-y divide-slate-200 text-left">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-6 py-4 text-sm font-semibold text-slate-700">Student</th>
              <th class="px-6 py-4 text-sm font-semibold text-slate-700">Bill</th>
              <th class="px-6 py-4 text-sm font-semibold text-slate-700">Amount</th>
              <th class="px-6 py-4 text-sm font-semibold text-slate-700">Status</th>
              <th class="px-6 py-4 text-sm font-semibold text-slate-700">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200">
            <% payments.forEach((payment) => { %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap">
                  <%= payment.studentId ? payment.studentId.name : 'Unknown user' %>
                  <% if (payment.studentId) { %>(<%= payment.studentId.rollNumber %>)<% } %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap"><%= payment.billId ? payment.billId.title : 'Deleted bill' %></td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if (payment.status === 'Due') { %>
                    <form action="/admin/edit-amount/<%= payment._id %>" method="POST" class="flex items-center gap-2">
                      <input name="amount" type="number" step="0.01" min="0" value="<%= payment.amountDue.toFixed(2) %>" class="w-28 rounded-2xl border border-slate-300 px-3 py-1" />
                      <button type="submit" class="rounded-2xl bg-slate-600 px-3 py-1 text-white">Save</button>
                    </form>
                  <% } else { %>
                    ₹<%= payment.amountDue.toFixed(2) %>
                  <% } %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="rounded-full px-3 py-1 text-sm font-semibold <%= payment.status === 'Paid' ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>"><%= payment.status %></span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if (payment.status === 'Due') { %>
                    <form action="/admin/mark-paid/<%= payment._id %>" method="POST">
                      <button type="submit" class="rounded-2xl bg-indigo-600 px-4 py-2 text-white hover:bg-indigo-700 transition">Mark Paid</button>
                    </form>
                  <% } else { %>
                    <span class="text-slate-500">Completed</span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl font-semibold mb-4">Expenses History</h2>
      <div class="space-y-4">
        <% if (expenses && expenses.length > 0) { %>
          <% expenses.forEach((expense) => { %>
            <div class="rounded-2xl bg-white p-5 border border-slate-200 shadow-sm">
              <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                <div>
                  <h3 class="text-lg font-semibold"><%= expense.title %> — ₹<%= expense.amount.toFixed(2) %></h3>
                  <p class="text-sm text-slate-500"><%= expense.description || 'No description provided' %></p>
                  <p class="text-sm text-slate-500">By <%= expense.createdBy ? expense.createdBy.name : 'Unknown' %> on <%= new Date(expense.date).toDateString() %></p>
                  <% if (expense.billImage) { %>
                    <a href="<%= expense.billImage %>" target="_blank" class="mt-2 inline-block text-sm font-semibold text-indigo-600 hover:underline">View Bill</a>
                  <% } %>
                </div>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="rounded-2xl bg-white p-5 border border-slate-200 text-slate-600">No expenses recorded yet.</div>
        <% } %>
      </div>
    </section>

  </div>

  <script>
    function confirmReset() {
      if (confirm('This will delete all payments and expenses but keep all students. Continue?')) {
        if (confirm('Are you absolutely sure? This action cannot be undone.')) {
          fetch('/admin/reset-planning', { method: 'POST' })
            .then(res => res.json())
            .then(data => {
              if (data.success) {
                alert('Planning reset successfully!');
                location.reload();
              } else {
                alert('Error: ' + (data.message || 'Unknown error'));
              }
            })
            .catch(err => alert('Error: ' + err));
        }
      }
    }

    // Auto-refresh session every 3 seconds to detect role changes
    setInterval(async () => {
      try {
        const response = await fetch('/check-session');
        const data = await response.json();
        if (data.role && data.role !== '<%= currentUser.role %>') {
          console.log('Role changed to:', data.role);
          location.reload();
        }
      } catch (err) {
        console.error('Session check failed:', err);
      }
    }, 3000);
  </script>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    if (typeof io !== 'undefined') {
      const socket = io();
      socket.on('paymentUpdated', () => location.reload());
      socket.on('expenseCreated', () => location.reload());
      socket.on('billCreated', () => location.reload());
      socket.on('roleChanged', () => location.reload());
    }
  </script>
</body>
</html>
